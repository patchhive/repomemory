# ── Optional GitHub Access ────────────────────────────────────────────────────
# Recommended fine-grained PAT:
# Metadata (read), Pull requests (read), Issues (read).
# This unlocks merged PR, review feedback, and closed-issue ingestion.
# BOT_GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional app auth ─────────────────────────────────────────────────────────
# REPO_MEMORY_API_KEY_HASH=
# REPO_MEMORY_SERVICE_TOKEN_HASH=

# ── Storage ───────────────────────────────────────────────────────────────────
REPO_MEMORY_DB_PATH=repo-memory.db
REPO_MEMORY_PORT=8030

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
